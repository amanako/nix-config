{
	opts = {
    # Numbers
    number = true;
    relativenumber = true;
    wrap = false;
    cursorline = true;
    signcolumn = "yes";
    scrolloff = 21;
    sidescrolloff = 20;

    # Search 
    ignorecase = true;
    smartcase = true;
    incsearch = true;
    hlsearch = true;

    clipboard = "unnamedplus";

    # Tab/Shift
    shiftwidth = 2;
    tabstop = 2;

    # Swap
    swapfile = false;
    backup = false;
    writebackup = false;
    undofile = true;

    # Fold
    foldmethod = "indent";
    foldlevel = 99;
    foldenable = false;

    timeoutlen = 500;
    completeopt = "menuone,noselect";
    updatetime = 250;

    splitbelow = true;
    splitright = true;
  };
}
