{
  niri.input.homeManager.programs.niri.settings.input = {
    keyboard.track-layout = "window";

    touchpad = {
      dwt = true;
      accel-speed = 0.1;
      accel-profile = "adaptive";
      scroll-method = "two-finger";
    };

    mouse = {
      accel-speed = -0.5;
    };

    warp-mouse-to-focus.enable = true;
    workspace-auto-back-and-forth = true;

    mod-key = "Super";
    mod-key-nested = "Alt";
  };
}
